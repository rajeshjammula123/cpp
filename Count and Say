#include <string>
#include <vector>

using namespace std;

class Solution {
public:
    string countAndSay(int n) {
        if (n <= 0) return "";
        string res = "1";
        
        // Loop to generate the sequence up to n
        for (int i = 1; i < n; i++) {
            string current = "";
            int len = res.length();
            
            for (int j = 0; j < len; ) {
                int count = 0;
                char val = res[j];
                
                // Count consecutive occurrences
                while (j < len && res[j] == val) {
                    count++;
                    j++;
                }
                
                // C++ to_string converts the integer count to string
                current += to_string(count) + val;
            }
            res = current;
        }
        
        return res;
    }
};
