#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    int firstMissingPositive(vector<int>& nums) {
        int n = nums.size();
        
        for (int i = 0; i < n; i++) {
            // While the current number is in range [1, n] 
            // and it is not at its correct index (nums[i]-1)
            // Use long long or check carefully to avoid overflow if nums[i] is INT_MIN
            while (nums[i] > 0 && nums[i] <= n && nums[nums[i] - 1] != nums[i]) {
                swap(nums[i], nums[nums[i] - 1]);
            }
        }
        
        // Find the first index that doesn't match its value
        for (int i = 0; i < n; i++) {
            if (nums[i] != i + 1) {
                return i + 1;
            }
        }
        
        // If 1 through n are all present, the missing one is n + 1
        return n + 1;
    }
};
